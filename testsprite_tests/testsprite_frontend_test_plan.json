      },
      {
        "type": "action",
        "description": "Submit the login form"
      },
      {
        "type": "action",
        "description": "Click the navigation link to the dashboard"
      },
      {
        "type": "action",
        "description": "Select a Source filter value"
      },
      {
        "type": "action",
        "description": "Select a Category filter value"
      },
      {
        "type": "action",
        "description": "Select an Assignee filter value"
      },
      {
